{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System": "Information",
      "Microsoft": "Warning"
    },
    "Console": {
      "FormatterName": "simple"
    }
  },
  "AllowedHosts": "*",
  "JigenServer": {
    "Https": {
      "Mode": "None",
      "CertificatePath": "",
      "CertificatePassword": ""
    }
  },
  "JigenEmbeddings": {
    "TokenizerPath": "/data/onnx/nomic-embed-text-v1.5/tokenizer.onnx",
    "EmbeddingsModelPath": "/data/onnx/nomic-embed-text-v1.5/model_int8.onnx",
    "GeneratorOptions": {
      "MaxTokens": 2048,
      "UseChunking": true,
      "ChunkSize": 1536,
