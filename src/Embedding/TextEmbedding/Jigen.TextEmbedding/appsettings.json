    "EmbeddingsMaxConcurrency": 2,
    "EmbeddingsQueueCapacity": 10,
    "EmbeddingsQueueTimeoutSeconds": 60,
    "DefaultTask": "search_document",
    "Tasks": [
      "search_document",
      "search_query",
      "clustering",
      "classification"
    ]
  },
  "Kaido": {
    "Enabled": true
  },
  "RabbitMQ": {
    "HostName": "localhost",
    "Port": 5672,
    "ExchangeName": "JigenExchange",
    "UserName": "jigen",
    "Password": "P@ssw0rd",
    "VirtualHost": "Jigen",
    "PerChannelQos": 10,
    "PerConsumerQos": 10
  }
